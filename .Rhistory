#' =============================================================================
#' APIM using Moderators Approach for Distinguishable Dyadic Data
#' Workshop: Dyadic Data Analysis Using R
#' Example: Work-Nonwork Conflict, Recovery, and Relationship Satisfaction
#' =============================================================================
#'
#' This script demonstrates how to analyze distinguishable dyad data
#' using the Actor-Partner Interdependence Model (APIM) with gender
#' as a moderator in a multilevel regression framework (lme4).
#'
#' KEY IDEA: In the moderator approach, we include the distinguishing
#' variable (gender) and its interactions with predictors. This allows:
#'   (a) Different intercepts for husbands and wives
#'   (b) Testing whether actor and partner effects differ by gender
#'   (c) Estimating simple slopes for each group
#'
#' The moderator approach is equivalent to testing whether the
#' distinguishing variable moderates the predictor-outcome paths.
#'
#' LIMITATION: The basic moderator model with long-format data does
#' NOT automatically separate actor from partner effects. To do this
#' properly, we need to include explicit partner variables.
#'
#' We demonstrate TWO versions:
#'   Version A: Simple moderator model (no actor/partner separation)
#'   Version B: Full APIM moderator model with partner variables
#'
#' TRUE DGP PARAMETERS (for reference):
#'   Actor WNC effect (a_wnc)         = -0.30
#'   Partner WNC effect (p_wnc)       = -0.15
#'   Actor Recovery effect (a_rec)    =  0.25
#'   Partner Recovery effect (p_rec)  =  0.10
#'   Children effect (c_child)        = -0.10
#'   Dual-earner effect (c_dual)       =  0.20
#'   Husband intercept                =  5.00
#'   Wife intercept                   =  4.85
#'   Effects are EQUAL across gender
#'
#' Prerequisites: Run 01_simulate_data.R first
#' Input:        dyad_data.RData
#' Output:       distinguishable_apim_moderator_fit.RData
# =============================================================================
# 1. Load Libraries and Data
# =============================================================================
library(lme4)
library(lmerTest)
install.packages("lmerTest")
#' =============================================================================
#' APIM using Moderators Approach for Distinguishable Dyadic Data
#' Workshop: Dyadic Data Analysis Using R
#' Example: Work-Nonwork Conflict, Recovery, and Relationship Satisfaction
#' =============================================================================
#'
#' This script demonstrates how to analyze distinguishable dyad data
#' using the Actor-Partner Interdependence Model (APIM) with gender
#' as a moderator in a multilevel regression framework (lme4).
#'
#' KEY IDEA: In the moderator approach, we include the distinguishing
#' variable (gender) and its interactions with predictors. This allows:
#'   (a) Different intercepts for husbands and wives
#'   (b) Testing whether actor and partner effects differ by gender
#'   (c) Estimating simple slopes for each group
#'
#' The moderator approach is equivalent to testing whether the
#' distinguishing variable moderates the predictor-outcome paths.
#'
#' LIMITATION: The basic moderator model with long-format data does
#' NOT automatically separate actor from partner effects. To do this
#' properly, we need to include explicit partner variables.
#'
#' We demonstrate TWO versions:
#'   Version A: Simple moderator model (no actor/partner separation)
#'   Version B: Full APIM moderator model with partner variables
#'
#' TRUE DGP PARAMETERS (for reference):
#'   Actor WNC effect (a_wnc)         = -0.30
#'   Partner WNC effect (p_wnc)       = -0.15
#'   Actor Recovery effect (a_rec)    =  0.25
#'   Partner Recovery effect (p_rec)  =  0.10
#'   Children effect (c_child)        = -0.10
#'   Dual-earner effect (c_dual)       =  0.20
#'   Husband intercept                =  5.00
#'   Wife intercept                   =  4.85
#'   Effects are EQUAL across gender
#'
#' Prerequisites: Run 01_simulate_data.R first
#' Input:        dyad_data.RData
#' Output:       distinguishable_apim_moderator_fit.RData
# =============================================================================
# 1. Load Libraries and Data
# =============================================================================
library(lme4)
library(lmerTest)
library(dplyr)
load("dyad_data.RData")
# Rename _a/_p column labels (from unified dataset) to meaningful
# husb_/wife_ labels for distinguishable dyads
dyad_data_wide <- dyad_data_wide %>%
rename(
husb_wnc          = wnc_a,
wife_wnc          = wnc_p,
husb_recovery     = recovery_a,
wife_recovery     = recovery_p,
husb_satisfaction = satisfaction_a,
wife_satisfaction = satisfaction_p
)
cat("Data loaded. Dimensions:", dim(dyad_data_long), "\n")
cat("Variables:", paste(names(dyad_data_long), collapse = ", "), "\n")
head(dyad_data_long)
# =============================================================================
# 2. Prepare Data
# =============================================================================
dyad_data_long$gender <- factor(dyad_data_long$gender,
levels = c("husband", "wife"))
cat("\nGender levels:", paste(levels(dyad_data_long$gender), collapse = ", "), "\n")
cat("Reference group: husband (first level)\n")
cat("Partner variables already present in data:\n")
cat("  partner_wnc, partner_recovery\n\n")
cat("True DGP parameters:\n")
cat("  Actor WNC effect (a_wnc):        -0.30\n")
cat("  Partner WNC effect (p_wnc):      -0.15\n")
cat("  Actor Recovery effect (a_rec):     0.25\n")
cat("  Partner Recovery effect (p_rec):   0.10\n")
cat("  Children effect (c_child):        -0.10\n")
cat("  Dual-earner effect (c_dual):       0.20\n")
cat("  Husband intercept:                 5.00\n")
cat("  Wife intercept:                    4.85\n")
cat("  Effects are EQUAL across gender\n")
# =============================================================================
# 3. Version A: Simple Moderator Model (No Actor/Partner Separation)
# =============================================================================
#
# This model includes gender × predictor interactions but does NOT
# separate actor from partner effects. It tells us whether the
# effect of a predictor (pooled across actor and partner roles) differs
# by gender.
#
# Model: satisfaction ~ wnc * gender + recovery * gender
#                       + has_children + dual_earner + (1 | dyad_id)
#
# WARNING: This model conflates actor and partner effects. The
# coefficient for wnc represents a blend of own and partner influence
# because both members' wnc scores are in the same column. For a
# proper APIM decomposition, see Version B.
cat("\n============================================================\n")
cat("VERSION A: Simple Moderator Model\n")
cat("============================================================\n\n")
cat("Model: satisfaction ~ wnc * gender + recovery * gender\n")
cat("                    + has_children + dual_earner + (1 | dyad_id)\n\n")
cat("IMPORTANT: This model does NOT separate actor from partner effects.\n")
cat("The wnc coefficient conflates actor and partner influences.\n")
cat("It answers: 'Does the relationship between WNC and satisfaction\n")
cat("differ by gender?' — but not 'Does one's OWN vs. PARTNER'S WNC\n")
cat("matter differently?'\n\n")
simple_mod <- lmer(
satisfaction ~ wnc * gender + recovery * gender +
has_children + dual_earner + (1 | dyad_id),
data = dyad_data_long,
REML = TRUE
)
summary(simple_mod)
cat("\n--- Interpretation of Key Coefficients (Version A) ---\n")
fe_a <- fixef(simple_mod)
cat("  (Intercept) [husband]:          ", round(fe_a["(Intercept)"], 3), "\n")
cat("    True husband intercept:        5.000\n")
cat("  genderwife [intercept diff]:    ", round(fe_a["genderwife"], 3), "\n")
cat("    True wife intercept diff:     ", round(4.85 - 5.00, 3), "\n")
cat("  wnc [husband effect]:           ", round(fe_a["wnc"], 3), "\n")
cat("  wnc:genderwife [diff]:          ", round(fe_a["wnc:genderwife"], 3), "\n")
cat("  → Wife wnc effect:             ", round(fe_a["wnc"] + fe_a["wnc:genderwife"], 3), "\n")
cat("  recovery [husband effect]:      ", round(fe_a["recovery"], 3), "\n")
cat("  recovery:genderwife [diff]:    ", round(fe_a["recovery:genderwife"], 3), "\n")
cat("  → Wife recovery effect:        ", round(fe_a["recovery"] + fe_a["recovery:genderwife"], 3), "\n")
cat("  has_children:                  ", round(fe_a["has_children"], 3), "\n")
cat("    True children effect:         -0.100\n")
cat("  dual_earner:                   ", round(fe_a["dual_earner"], 3), "\n")
cat("    True dual-earner effect:       0.200\n\n")
cat("  NOTE: These effects pool actor and partner influence.\n")
cat("  The wnc estimate reflects a mix of one's own WNC and the\n")
cat("  partner's WNC (which is correlated with one's own via the\n")
cat("  dyadic structure). For a proper APIM, see Version B.\n")
summary(simple_mod)
