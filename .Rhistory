gs <- gstudy(Score ~ (1|Person) + (1|Task) + (1|Rater) + (1|Person:Task),
data = brennan, backend="brms", prior = prior_(~normal(0,1), class=~sd), cores =4)
g
gprint(g)
print(g)
print(gs)
gl
dstudy(gl)
dstudy(gs)
dstudy(g)
