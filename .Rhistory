dstudy(gs, universe = c("Person", "Person:Task"))
dstudy(gs, universe = c("Person", "Task"))
d <- dstudy(gs, n =list(Task = c(1,2,3, 4,5,10,15), Rater = c(2,4,6,8,10)), estimation = "posterior")
d <- dstudy(gs, n =list(Task = c(1,2,3, 4,5,10,15), Rater = c(2,4,6,8,10)), estimation = "posterior")
d
