gl <- gstudy(Score ~ (1|Person) + (1|Task) + (1|Rater) + (1|Person:Task), data = brennan, backend="lme4")
#gs <- gstudy(Score ~ (1|Person) + (1|Task) + (1|Rater) + (1|Person:Task), data = brennan, backend="brms")
d <- dstudy(gl, n =list(Task = c(1,2,3, 4,5,10,15), Rater = c(2,4,6,8,10)))
dstudy(gl)
devtools::document(roclets = c('rd', 'collate', 'namespace'))
devtools::build(binary = TRUE, args = c('--preclean'))
install.packages("~/Documents/Research/Rdevelopment/facet_0.0.1_R_x86_64-pc-linux-gnu.tar.gz", repos = NULL, type = "source")
library(facet)
brennan <- readRDS("~/Documents/Research/Rdevelopment/facet/data/brennan.rds")
gm <- gstudy(Score ~ (1|Person) + (1|Task) + (1|Rater) + (1|Person:Task), data = brennan, backend="mom")
gl <- gstudy(Score ~ (1|Person) + (1|Task) + (1|Rater) + (1|Person:Task), data = brennan, backend="lme4")
d <- dstudy(gl, n =list(Task = c(1,2,3, 4,5,10,15), Rater = c(2,4,6,8,10)))
d
dstudy(gl)
brennan <- readRDS("~/Documents/Research/Rdevelopment/facet/data/brennan.rds")
gs <- gstudy(Score ~ (1|Person) + (1|Task) + (1|Rater) + (1|Person:Task),
data = brennan, backend="brms", prior = prior_(~normal(0,1), class=~sd))
gs
dstudy(gs)
