#devtools::install()
install.packages("~/Documents/Research/Rdevelopment/facet_0.0.1_R_x86_64-pc-linux-gnu.tar.gz", repos = NULL, type = "source")
library(tidyr)
library(facet)
raj <- readRDS("~/Documents/Research/Rdevelopment/facet/data/rajaratnam.rds")
raj$Subtest <- paste0("test", raj$Subtest)
rajl <- raj |>
pivot_wider(
names_from = Subtest,
names_sep = ".",
values_from = c(Score)
)
gmom <- gstudy(mvbind(test1, test2, test3) ~ (1|Person) + (1|Item), data = rajl, backend="mom")
summary(gmom)
gmom <- gstudy(mvbind(test1, test2, test3) ~ (1|Person) + (1|Item) + set_rescor(TRUE), data = rajl, backend="mom")
g <- gstudy(bf(mvbind(test1, test2, test3) ~ (1|Person) + (1|Item)) + set_rescor(TRUE),
data = rajl, backend="brms", cores =4)
summary(gmom)
gmom <- gstudy(mvbind(test1, test2, test3) ~ (1|Person) + (1|Item) + set_rescor(TRUE), data = rajl, backend="mom")
summary(gmom)
gmom <- gstudy(mvbind(test1, test2, test3) ~ (1|Person) + (1|Item) + set_rescor(FALSE), data = rajl, backend="mom")
summary(gmom)
gmom <- gstudy(mvbind(test1, test2, test3) ~ (1|cor_r|Person) + (1|Item) + set_rescor(FALSE), data = rajl, backend="mom")
